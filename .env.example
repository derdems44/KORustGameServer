# Knight Online Rust Server -- Environment Configuration
# Copy this file: cp .env.example .env
# Then edit .env with your actual values.

# --- Database ---
# Full connection string for the game database.
DATABASE_URL=postgresql://koserver:changeme@localhost:5432/ko_server

# PostgreSQL password (used by docker-compose)
DB_PASSWORD=changeme

# PostgreSQL external port (optional, for docker-compose)
DB_PORT=5432

# --- Network ---
# Address the server binds to (0.0.0.0 = all interfaces)
BIND_IP=0.0.0.0

# Game server bind address (ip:port)
BIND_ADDR=0.0.0.0:15001

# Login server base port (uses range BASE_PORT to BASE_PORT+9)
BASE_PORT=15100

# Public IP that clients connect to (set this to your server's external IP)
GAME_SERVER_IP=your.server.ip

# Game server port advertised to clients
GAME_SERVER_PORT=15001

# --- Paths ---
# Directory containing SMD map files
MAP_DIR=./Map

# --- Logging ---
# Log level: error, warn, info, debug, trace
RUST_LOG=info
